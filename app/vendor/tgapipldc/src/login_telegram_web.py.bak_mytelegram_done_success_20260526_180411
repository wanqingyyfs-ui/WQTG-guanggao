            hard_refresh_telegram_page(page, TELEGRAM_SERVICE_CHAT_URL, label="#777000 守护", wait_ms=7000)

    print("3x5 守护结束后仍未确认 #777000。")
    return False

def normalize_message_text(text: str) -> str:
    text = unescape(text or "")
    text = text.replace("\u200b", "").replace("\u200c", "").replace("\u200d", "")
    return re.sub(r"\s+", " ", text).strip()


def normalize_777000_snapshot(snapshot: dict[str, Any] | None) -> dict[str, str]:
    snapshot = snapshot or {}
    text = normalize_message_text(str(snapshot.get("text") or ""))
    timestamp = normalize_message_text(str(snapshot.get("timestamp") or ""))
    message_id = normalize_message_text(str(snapshot.get("message_id") or ""))
    time_text = normalize_message_text(str(snapshot.get("time_text") or ""))
    time_title = normalize_message_text(str(snapshot.get("time_title") or ""))
    dom_index = normalize_message_text(str(snapshot.get("dom_index") or ""))
    time_marker = timestamp or time_title or time_text or message_id
    key = "||".join([time_marker, message_id, dom_index, text]).strip("|")
    return {
        "text": text,
        "timestamp": timestamp,
        "message_id": message_id,
        "time_text": time_text,
        "time_title": time_title,
        "dom_index": dom_index,
        "time_marker": time_marker,
        "key": key,
    }


def format_777000_snapshot(snapshot: dict[str, Any]) -> str:
    item = normalize_777000_snapshot(snapshot)
    return f"time={item.get('time_marker') or '无可用时间'} text={(item.get('text') or '')[:300]}"



def latest_777000_dom_snapshot(page) -> dict[str, str]:
    """
    读取当前 #777000 聊天窗口里的最新消息。

    修复点：不要求消息 bubble 自身带 data-peer-id="777000"。
    进入 #777000 当前聊天后，只从中间聊天窗口/消息容器读取真实消息节点，
    优先使用 data-timestamp + data-mid；没有数值属性时，退到消息时间文本/title + DOM 顺序。
    """
    scroll_777000_to_bottom(page)
    page.wait_for_timeout(700)
    try:
        data = page.evaluate(
            """
            () => {
                function clean(text) {
                    return String(text || '')
                        .replace(/[\u200b\u200c\u200d]/g, '')
                        .replace(/\\s+/g, ' ')
                        .trim();
                }

                function toInt(value) {
                    const n = parseInt(String(value || '').replace(/\\D/g, ''), 10);
                    return Number.isFinite(n) ? n : 0;
                }

                function visible(el) {
                    const rect = el.getBoundingClientRect();
                    const style = window.getComputedStyle(el);
                    return style
                        && style.display !== 'none'
                        && style.visibility !== 'hidden'
                        && rect.width > 0
                        && rect.height > 0;
                }

                function pickFirstText(el, selectors) {
                    for (const selector of selectors) {
                        const item = el.querySelector(selector);
                        const text = item ? clean(item.innerText || item.textContent || '') : '';
                        if (text) return text;
                    }
                    return '';
                }

                function pickFirstAttr(el, selectors, attrs) {
                    for (const selector of selectors) {
                        const item = el.querySelector(selector);
                        if (!item) continue;
                        for (const attr of attrs) {
                            const value = clean(item.getAttribute(attr) || '');
                            if (value) return value;
                        }
                    }
                    return '';
                }

                function pickText(el) {
                    const text = pickFirstText(el, [
                        '.translatable-message',
                        '.message .translatable-message',
                        '.message.spoilers-container',
                        '.message',
                        '.text-content',
                        '.bubble-content .service-msg',
                        '.bubble-content',
                    ]) || clean(el.innerText || el.textContent || '');

                    return text;
                }

                function pickTime(el) {
                    const timeSelectors = [
                        '.time-inner',
                        '.message .time-inner',
                        '.time .i18n',
                        '.time',
                        '.message-time .i18n',
                        '.message-time',
                        'time',
                    ];
                    return {
                        time_text: pickFirstText(el, timeSelectors),
                        time_title: pickFirstAttr(el, timeSelectors, ['title', 'aria-label', 'datetime', 'data-timestamp']),
                    };
                }

                function attrFromSelfOrClosest(el, attrName) {
                    const own = clean(el.getAttribute(attrName) || '');
                    if (own) return own;
                    const holder = el.closest('[data-mid], [data-timestamp], [data-message-id], [data-msg-id], .bubble');
                    return holder ? clean(holder.getAttribute(attrName) || '') : '';
                }

                function collectRoots() {
                    const selectors = [
                        '#column-center .bubbles',
                        '#column-center .chat',
                        '#column-center',
                        '.column-center .bubbles',
                        '.column-center',
                        '.chat[data-type="chat"] .bubbles',
                        '.chat[data-type="chat"]',
                        '.bubbles',
                    ];
                    const roots = [];
                    for (const selector of selectors) {
                        for (const item of Array.from(document.querySelectorAll(selector))) {
                            if (visible(item) && !roots.includes(item)) roots.push(item);
                        }
                    }
                    if (!roots.length) roots.push(document.body);
                    return roots;
                }

                const messageSelectors = [
                    'div.bubble[data-mid][data-timestamp]',
                    'div.bubble[data-mid]',
                    '[data-mid][data-timestamp]',
                    '[data-mid]',
                    '.bubbles div.bubble',
                    'div.bubble',
                    '.message',
                    '.text-content',
                ];

                const candidates = [];
                const seen = new Set();
                for (const root of collectRoots()) {
                    for (const selector of messageSelectors) {
                        for (const el of Array.from(root.querySelectorAll(selector))) {
                            if (seen.has(el)) continue;
                            seen.add(el);
                            if (!visible(el)) continue;

                            const rect = el.getBoundingClientRect();
                            const text = pickText(el);
                            if (!text || /^\\d{1,2}:\\d{2}$/.test(text)) continue;

                            const time = pickTime(el);
                            const timestamp = attrFromSelfOrClosest(el, 'data-timestamp')
                                || clean(el.getAttribute('datetime') || '')
                                || time.time_title;
                            const messageId = attrFromSelfOrClosest(el, 'data-mid')
                                || attrFromSelfOrClosest(el, 'data-message-id')
                                || attrFromSelfOrClosest(el, 'data-msg-id')
                                || clean(el.id || '');

                            candidates.push({
                                source: 'current-chat-message',
                                dom_index: candidates.length,
                                text,
                                timestamp,
                                message_id: messageId,
                                time_text: time.time_text,
                                time_title: time.time_title,
                                timestamp_score: toInt(timestamp),
                                mid_score: toInt(messageId),
                                top: rect.top,
                                bottom: rect.bottom,
                                left: rect.left,
                                height: rect.height,
                            });
                        }
                    }
                }

                candidates.sort((a, b) => {
                    if (a.timestamp_score !== b.timestamp_score) return b.timestamp_score - a.timestamp_score;
                    if (a.mid_score !== b.mid_score) return b.mid_score - a.mid_score;
                    if (a.bottom !== b.bottom) return b.bottom - a.bottom;
                    return b.dom_index - a.dom_index;
                });

                return candidates[0] || {};
            }
            """,
        )
        return normalize_777000_snapshot(data or {})
    except Exception as e:
        print(f"读取 #777000 当前聊天窗口消息失败：{e}")
        return {}

