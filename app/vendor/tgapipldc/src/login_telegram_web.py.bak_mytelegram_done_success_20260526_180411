def normalize_phone(phone: str) -> str:
    phone = (phone or "").strip()
    phone = re.sub(r"[\s\-()]+", "", phone)
    if not phone:
        raise ValueError("手机号为空")
    if not phone.startswith("+"):
        phone = "+" + phone
    return phone


def split_phone_for_telegram(phone: str, country: str = "") -> tuple[str, str, str]:
    normalized_phone = normalize_phone(phone)
    digits = re.sub(r"\D", "", normalized_phone)
    country = (country or "").strip().upper()
    if not digits:
        raise ValueError("手机号没有数字")

    country_code_digits = COUNTRY_CODE_BY_COUNTRY.get(country, "")
    if country_code_digits:
        if digits.startswith(country_code_digits) and len(digits) > len(country_code_digits):
            national_number = digits[len(country_code_digits):]
            telegram_phone = f"+{digits}"
        else:
            national_number = digits
            telegram_phone = f"+{country_code_digits}{national_number}"
        if not national_number:
            raise ValueError(f"手机号缺少本地号码部分：{normalized_phone}")
        return telegram_phone, f"+{country_code_digits}", national_number

    if digits.startswith("1") and len(digits) == 11:
        return f"+{digits}", "+1", digits[1:]

    return normalized_phone, "", digits


def read_account_proxy_map() -> list[dict[str, str]]:
    if not ACCOUNT_PROXY_MAP_FILE.exists():
        raise FileNotFoundError(f"找不到文件：{ACCOUNT_PROXY_MAP_FILE}")

    with open(ACCOUNT_PROXY_MAP_FILE, "r", encoding="utf-8-sig", newline="") as f:
        reader = csv.DictReader(f)
        required_fields = {
            "phone",
            "country",
            "profile_dir",
            "raw_proxy",
            "masked_proxy",
            "exit_ip",
            "status",
            "note",
            "yanzheng",
        }
        current_fields = set(reader.fieldnames or [])
        missing_fields = required_fields - current_fields
        if missing_fields:
            raise ValueError(f"account_proxy_map.csv 缺少字段：{missing_fields}")

        rows: list[dict[str, str]] = []
        for row in reader:
            phone = (row.get("phone") or "").strip()
            raw_proxy = (row.get("raw_proxy") or "").strip()
            profile_dir = (row.get("profile_dir") or "").strip()
            country = (row.get("country") or "").strip()
            if not phone or not raw_proxy or not profile_dir:
                continue

            telegram_phone, country_code, national_number = split_phone_for_telegram(phone, country)
            rows.append({
                "phone": phone,
                "telegram_phone": telegram_phone,
                "country_code": country_code,
                "national_number": national_number,
                "country": country,
                "profile_dir": profile_dir,
                "raw_proxy": raw_proxy,
                "masked_proxy": (row.get("masked_proxy") or "").strip(),
                "exit_ip": (row.get("exit_ip") or "").strip(),
                "status": (row.get("status") or "").strip(),
                "note": (row.get("note") or "").strip(),
                "yanzheng": (row.get("yanzheng") or "").strip(),
            })

    if not rows:
        raise ValueError("account_proxy_map.csv 里没有可用账号代理绑定")
    return rows


def select_account(rows: list[dict[str, str]]) -> dict[str, str]:
    if len(sys.argv) >= 2:
        target_phone = sys.argv[1].strip()
        for row in rows:
            if row["phone"] == target_phone or row["telegram_phone"] == target_phone:
                return row
        raise ValueError(f"没有找到手机号：{target_phone}")

    print("可用账号列表：")
    for index, row in enumerate(rows, start=1):
        print(
            f"{index}. {row['phone']} / {row['telegram_phone']} -> "
            f"{row['masked_proxy']} -> 当前记录IP {row['exit_ip']}"
        )

    selected = input("请输入要登录 Telegram Web 的账号序号：").strip()
    try:
        selected_index = int(selected)
    except ValueError:
        raise ValueError("请输入数字序号")
    if selected_index < 1 or selected_index > len(rows):
        raise ValueError("账号序号超出范围")
    return rows[selected_index - 1]


def update_account_proxy_map_exit_ip(phone: str, new_exit_ip: str):
    if not ACCOUNT_PROXY_MAP_FILE.exists():
        raise FileNotFoundError(f"找不到文件：{ACCOUNT_PROXY_MAP_FILE}")

    with open(ACCOUNT_PROXY_MAP_FILE, "r", encoding="utf-8-sig", newline="") as f:
        reader = csv.DictReader(f)
        fieldnames = reader.fieldnames or []
        rows = list(reader)

    if "phone" not in fieldnames or "exit_ip" not in fieldnames:
        raise ValueError("account_proxy_map.csv 缺少 phone 或 exit_ip 字段")

    updated = False
    for row in rows:
        if (row.get("phone") or "").strip() == phone:
            row["exit_ip"] = new_exit_ip
            row["status"] = "telegram_proxy_verified"
            row["note"] = "exit_ip_updated_before_telegram_login"
