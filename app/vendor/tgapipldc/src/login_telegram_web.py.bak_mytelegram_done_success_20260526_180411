def first_visible(locator, timeout: int = 1000):
    try:
        count = locator.count()
    except Exception:
        count = 0

    for index in range(count):
        item = locator.nth(index)
        try:
            if item.is_visible(timeout=timeout):
                return item
        except Exception:
            continue
    return None


def click_named(page, name_regex: re.Pattern, timeout: int = 4000) -> bool:
    candidates = [
        page.get_by_role("button", name=name_regex),
        page.get_by_role("link", name=name_regex),
        page.locator("button").filter(has_text=name_regex),
        page.locator("a").filter(has_text=name_regex),
        page.get_by_text(name_regex),
        page.locator(".btn-primary").filter(has_text=name_regex),
    ]

    for candidate in candidates:
        item = first_visible(candidate, timeout=timeout)
        if item is None:
            continue
        try:
            item.scroll_into_view_if_needed(timeout=2000)
        except Exception:
            pass
        try:
            item.click(timeout=timeout)
            return True
        except Exception:
            try:
                item.click(timeout=timeout, force=True)
                return True
            except Exception:
                continue
    return False


def locator_context_text(locator) -> str:
    try:
        return locator.evaluate(
            """
            (el) => {
                const inputField = el.closest('.input-field');
                const row = el.closest('.row');
                const form = el.closest('form');
                const parent = el.parentElement;
                const pieces = [
                    el.innerText || el.textContent || '',
                    el.getAttribute('aria-label') || '',
                    el.getAttribute('placeholder') || '',
                    inputField ? (inputField.innerText || inputField.textContent || '') : '',
                    row ? (row.innerText || row.textContent || '') : '',
                    parent ? (parent.innerText || parent.textContent || '') : '',
                    form ? (form.innerText || form.textContent || '') : '',
                    el.outerHTML || ''
                ];
                return pieces.join(' ');
            }
            """
        ) or ""
    except Exception:
        return ""


