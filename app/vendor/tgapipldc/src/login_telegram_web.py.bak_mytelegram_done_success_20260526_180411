                update_account_proxy_map_exit_ip(account["phone"], browser_ip)

            print("代理检测通过，准备自动打开 Telegram Web、填写手机号并点击确认。")
            print("-" * 80)

            telegram_page = context.new_page()
            auto_flow_error = ""
            mytelegram_done = False
            try:
                mytelegram_done = bool(auto_start_telegram_phone_login(
                    page=telegram_page,
                    phone=account["telegram_phone"],
                    country=account["country"],
                    yanzheng_url=account["yanzheng"],
                ))
            except Exception as e:
                auto_flow_error = str(e)
                print("自动流程失败，已记录失败原因，准备跳过当前账号。")
                print(f"错误：{auto_flow_error}")
                dump_debug_html(telegram_page, "telegram_auto_flow_failed")

            automation_note = get_last_automation_note()
            if auto_flow_error:
                telegram_status = "telegram_auto_flow_failed"
                note_parts = [f"auto_flow_error: {auto_flow_error}"]
                if automation_note:
                    note_parts.append(automation_note)
                note = " | ".join(note_parts)
                success = False
            elif mytelegram_done:
                telegram_status = "api_export_success"
                note = automation_note or "my.telegram.org API 导出成功"
                success = True
            else:
                telegram_status = "api_export_failed"
                note = automation_note or "my.telegram.org 自动流程未完成或未成功写入 API CSV"
                success = False

            if automation_note:
                print(f"自动流程备注：{automation_note}")

            append_login_status({
                "phone": account["phone"],
                "profile_dir": account["profile_dir"],
                "proxy": parsed_proxy.masked_raw_proxy,
                "exit_ip": browser_ip,
                "telegram_status": telegram_status,
                "note": note,
                "updated_at": now_text(),
            })

            print(f"登录状态已写入：{TELEGRAM_LOGIN_STATUS_FILE}")
            return success, note
        finally:
            if context is not None:
                try:
                    context.close()
                except Exception:
                    pass


def _account_match_keys(row: dict[str, str]) -> set[str]:
    keys: set[str] = set()

    def add(value: str):
        value = (value or "").strip()
        digits = re.sub(r"\D", "", value)
        if value:
            keys.add(value)
        if digits:
            keys.add(digits)
            keys.add(f"+{digits}")

    add(row.get("phone") or "")
    add(row.get("telegram_phone") or "")
    add(row.get("phone_for_web") or "")

    country_code_digits = re.sub(r"\D", "", row.get("country_code") or "")
    national_number_digits = re.sub(r"\D", "", row.get("national_number") or "")
    if country_code_digits and national_number_digits:
        add(f"+{country_code_digits}{national_number_digits}")
        add(f"{country_code_digits}{national_number_digits}")
    if national_number_digits:
        add(national_number_digits)

    return keys


def read_original_accounts_csv_index() -> tuple[list[str], dict[str, dict[str, str]]]:
    if not ACCOUNTS_FILE.exists():
        raise FileNotFoundError(f"找不到原始账号文件，无法按原 accounts.csv 字段写入失败.csv：{ACCOUNTS_FILE}")

    with open(ACCOUNTS_FILE, "r", encoding="utf-8-sig", newline="") as f:
        reader = csv.DictReader(f)
        fieldnames = list(reader.fieldnames or [])
        if not fieldnames:
            raise ValueError(f"accounts.csv 没有表头，无法按原字段写入失败.csv：{ACCOUNTS_FILE}")

        index: dict[str, dict[str, str]] = {}
        for row in reader:
            clean_row = {field: (row.get(field) or "") for field in fieldnames}
            for key in _account_match_keys(clean_row):
                index.setdefault(key, clean_row)

    return fieldnames, index


def find_original_account_row(account: dict[str, str], accounts_index: dict[str, dict[str, str]]) -> dict[str, str] | None:
    for key in _account_match_keys(account):
        if key in accounts_index:
            return accounts_index[key]
    return None


def ensure_failure_csv_header(file_path: Path, fieldnames: list[str]) -> bool:
    if not file_path.exists():
        return False

    try:
        with open(file_path, "r", encoding="utf-8-sig", newline="") as f:
            reader = csv.reader(f)
            current_header = next(reader, [])
    except Exception:
        current_header = []

    if current_header == fieldnames:
        return True

    # 失败.csv 必须严格等于 accounts.csv 字段；旧版错误表头直接重建。
    with open(file_path, "w", encoding="utf-8-sig", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
    return True


def write_batch_account_result(
    index: int,
    account: dict[str, str],
    success: bool,
    reason: str,
    accounts_fieldnames: list[str],
    accounts_index: dict[str, dict[str, str]],
):
    if success:
        return

    CSV_OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    file_path = CSV_OUTPUT_DIR / "失败.csv"

    original_row = find_original_account_row(account, accounts_index)
    if original_row is None:
        original_row = {field: (account.get(field) or "") for field in accounts_fieldnames}

    row_to_write = {field: (original_row.get(field) or "") for field in accounts_fieldnames}

    file_has_header = ensure_failure_csv_header(file_path, accounts_fieldnames)

    with open(file_path, "a", encoding="utf-8-sig", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=accounts_fieldnames)
        if not file_has_header:
            writer.writeheader()
        writer.writerow(row_to_write)

    print(f"失败账号已按 accounts.csv 原字段写入失败汇总 CSV：{file_path}。失败原因仅打印不写入该 CSV：{reason}")


def main():
    rows = read_account_proxy_map()
    accounts_fieldnames, accounts_index = read_original_accounts_csv_index()
    total = len(rows)
    print("=" * 80)
    print(f"批量自动模式：共读取到 {total} 个账号，将从账号 1 开始依次执行。")
    print("不再手动选择账号；成功导出 API 后自动进入下一个账号，失败会记录原因并跳过。")
    print("=" * 80)

    success_count = 0
    failed_count = 0

    for index, account in enumerate(rows, start=1):
        print("\n" + "#" * 80)
        print(f"开始处理账号 {index}/{total}：{account['phone']}")
        print("#" * 80)

        try:
            success, reason = open_telegram_web_for_login(account)
        except Exception as e:
            success = False
            reason = f"batch_unhandled_error: {e}"
            print(f"账号 {account['phone']} 执行出现未捕获错误，已跳过：{e}")

        write_batch_account_result(index, account, success, reason, accounts_fieldnames, accounts_index)

        if success:
            success_count += 1
            print(f"账号 {account['phone']} API 记录成功，继续下一个账号。")
        else:
            failed_count += 1
            print(f"账号 {account['phone']} 执行失败，原因：{reason}")
            print("跳过当前账号，继续下一个账号。")

        time.sleep(2)

    print("=" * 80)
    print(f"批量执行完成：成功 {success_count} 个，失败 {failed_count} 个，总计 {total} 个。")
    print("=" * 80)


if __name__ == "__main__":
    main()
