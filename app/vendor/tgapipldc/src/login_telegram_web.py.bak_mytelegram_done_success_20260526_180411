def snapshot_has_real_message_order(snapshot: dict[str, str]) -> bool:
    """判断是否已经读到当前聊天窗口的一条真实消息。"""
    normalized = normalize_777000_snapshot(snapshot)
    if not normalized.get("text"):
        return False
    return bool(normalized.get("time_marker") or normalized.get("message_id") or normalized.get("dom_index"))


def get_latest_777000_message_snapshot(page, allow_chatlist_fallback: bool = False) -> dict[str, str]:
    """
    读取 #777000 当前最新消息。

    默认读取当前聊天窗口真实消息节点，不要求 bubble 自带 peer-id。
    只有人工诊断时才允许 fallback 到左侧聊天列表 preview。
    """
    dom_snapshot = latest_777000_dom_snapshot(page)
    if snapshot_has_real_message_order(dom_snapshot):
        return normalize_777000_snapshot(dom_snapshot)
    if allow_chatlist_fallback:
        return latest_777000_chatlist_snapshot(page)
    return {}


def wait_for_latest_777000_message_snapshot(page, timeout: int = 45000) -> dict[str, str]:
    """
    等待并读取 #777000 当前最新消息，作为 my.telegram.org 请求验证码前的基准。

    优先使用 data-timestamp/data-mid；如果 Telegram 当前版本没有暴露这些属性，
    仍记录当前聊天窗口底部真实消息的 time/title/dom_index/text 作为基准。
    """
    deadline = time.time() + timeout / 1000
    last_snapshot: dict[str, str] = {}
    attempt = 1

    while time.time() < deadline:
        if "#777000" not in (page.url or ""):
            open_telegram_service_chat(page, timeout=30000)

        snapshot = get_latest_777000_message_snapshot(page, allow_chatlist_fallback=False)
        normalized = normalize_777000_snapshot(snapshot)
        if snapshot_has_real_message_order(normalized):
            print(f"已记录 #777000 当前最新消息基准：{format_777000_snapshot(normalized)}")
            return normalized

        last_snapshot = normalized or last_snapshot
        print("#777000 当前聊天窗口消息基准暂未读到，滚到底/刷新后继续。")
        scroll_777000_to_bottom(page)
        if attempt % 2 == 0:
            safe_reload_or_goto(page, TELEGRAM_SERVICE_CHAT_URL, label="#777000", wait_ms=3000)
        page.wait_for_timeout(1200)
        attempt += 1

    raise TimeoutError(f"进入 #777000 后没有读到当前聊天窗口最新消息基准，最后快照：{format_777000_snapshot(last_snapshot)}")

def record_stable_777000_baseline(page, timeout: int = 45000, settle_ms: int = 3000) -> dict[str, str]:
    """
    在访问 my.telegram.org 前彻底记录 #777000 当前最新消息。
    先读取一次，等待 3 秒后再次读取；如果第二次消息更新，则以第二次为最终基准。
    """
    first_snapshot = wait_for_latest_777000_message_snapshot(page, timeout=timeout)
    print(f"#777000 第一次基准：{format_777000_snapshot(first_snapshot)}")
    print(f"#777000 基准记录后等待 {settle_ms // 1000} 秒，再复核当前最新消息。")
    page.wait_for_timeout(settle_ms)

    second_snapshot = wait_for_latest_777000_message_snapshot(page, timeout=timeout)
    first_order = snapshot_to_order(first_snapshot)
    second_order = snapshot_to_order(second_snapshot)

    if second_order >= first_order:
        final_snapshot = normalize_777000_snapshot(second_snapshot)
    else:
        final_snapshot = normalize_777000_snapshot(first_snapshot)

    print(f"#777000 最终基准已确认：{format_777000_snapshot(final_snapshot)}")
    return final_snapshot


def normalize_candidate_code(raw_code: str) -> str:
    code = unescape(raw_code or "")
    code = code.replace("\u200b", "").replace("\u200c", "").replace("\u200d", "")
    code = code.strip().strip(" \t\r\n\"'`“”‘’()[]{}<>")
    code = code.rstrip(".。,，;；")
    return code.strip()


def is_valid_candidate_code(code: str) -> bool:
    if not code or len(code) < 4 or len(code) > 64:
        return False
    lowered = code.lower()
    blocked_exact = {
        "code", "login", "password", "telegram", "my.telegram.org", "https", "http", "www",
        "from", "this", "your", "verification", "confirmation", "attempt", "account", "website",
        "browser", "message", "messages", "copied", "clipboard", "copy", "button", "sign",
        "next", "signin", "sign in", "code copied to clipboard",
    }
    if lowered in blocked_exact or lowered.startswith("http") or "://" in lowered:
        return False
    if re.fullmatch(r"[\u4e00-\u9fff]+", code):
        return False

    has_digit = bool(re.search(r"\d", code))
    has_upper = bool(re.search(r"[A-Z]", code))
    has_lower = bool(re.search(r"[a-z]", code))
    has_symbol = bool(re.search(r"[^A-Za-z0-9]", code))

    if has_digit:
        return True

    if has_upper and has_lower and len(code) >= 6:
        return True

    if has_symbol and (has_upper or has_lower):
        return True

    return False


def extract_candidate_codes_from_text(text: str) -> list[str]:
    text = unescape(text or "")
    candidates: list[str] = []

    def append(raw: str):
        code = normalize_candidate_code(raw)
        if is_valid_candidate_code(code) and code not in candidates:
            candidates.append(code)

    code_label = r"(?:login\s*code|verification\s*code|confirmation\s*code|my\.telegram\.org\s*code|code|password|验证码|登录码|登入码|代碼|コード)"
    code_token = r"([A-Za-z0-9@#$_*+=:,.!?\-~%^&/\\]{4,64})"
    strict_code_token = r"([A-Za-z0-9]{5,32})"
    patterns = [
        rf"(?:this\s+is\s+your\s+login\s+code|your\s+login\s+code|login\s+code)\s*[:：]\s*{strict_code_token}",
        rf"(?:这是|這是).{{0,20}}?(?:登录|登入|驗證|验证).{{0,20}}?(?:码|碼)\s*[:：]\s*{strict_code_token}",
        rf"{code_label}[\s\S]{{0,160}}?{code_token}",
        rf"{code_token}[\s\S]{{0,120}}?{code_label}",
        r"[`'\"“”‘’]([A-Za-z0-9@#$_*+=:,.!?\-~%^&/\\]{4,64})[`'\"“”‘’]",
        r"\b(\d{5,8})\b",
    ]
    for pattern in patterns:
        for match in re.finditer(pattern, text, re.IGNORECASE):
            append(match.group(1))
        if candidates:
            return candidates
    return candidates



def snapshot_to_order(snapshot: dict[str, str]) -> tuple[int, int, int]:
    normalized = normalize_777000_snapshot(snapshot)
    timestamp = int(re.sub(r"\D", "", normalized.get("timestamp") or "0") or 0)
    message_id = int(re.sub(r"\D", "", normalized.get("message_id") or "0") or 0)
    dom_index = int(re.sub(r"\D", "", normalized.get("dom_index") or "0") or 0)
    return timestamp, message_id, dom_index






