    except Exception as e:
        set_last_automation_result("mytelegram_failed", str(e))
        print(f"my.telegram.org 自动流程失败：{e}")
        print("浏览器会保持打开，可以手动检查 my.telegram.org 或 #777000。")
        return False

def wait_for_telegram_state(page, target_states: set[str], timeout: int = 30000) -> str:
    deadline = time.time() + timeout / 1000
    last_state = "unknown"
    while time.time() < deadline:
        last_state = get_telegram_page_state(page)
        if last_state in target_states:
            return last_state
        page.wait_for_timeout(700)
    return last_state



def auto_start_telegram_phone_login(page, phone: str, country: str = "", yanzheng_url: str = ""):
    page = open_telegram_web_until_ready(page, max_page_reopens=3)
    print("Telegram Web 首屏已可识别，开始状态机。")

    set_last_automation_result("", "")
    handled_phone = False
    handled_code = False
    mytelegram_done = False
    restart_count = 0
    max_restarts = 3

    print("第一优先级：检查当前是否已经登录 Telegram，并尝试确认 #777000 官方消息。")
    if is_telegram_logged_in_page(page, timeout=1500):
        print("当前已是 Telegram 已登录聊天界面，跳过 Telegram 登录流程。")
        if not open_telegram_service_chat_guarded(page, reason="当前已登录，准备跳过 Telegram 登录流程并确认 #777000", checks_per_round=5, max_refresh_rounds=3, interval_ms=2000):
            page = restart_telegram_page_from_scratch(page, label="#777000 首次确认失败后重新打开")
        else:
            mytelegram_done = run_mytelegram_org_flow_after_777000(page, phone)
            print("-" * 80)
            print("Telegram 已登录，已跳过登录流程。")
            print("my.telegram.org 自动流程状态：" + ("已完成" if mytelegram_done else "未完成或需人工检查"))
            print("-" * 80)
            return

    print("当前没有确认已登录/#777000，进入未登录状态机。")
    deadline = time.time() + 300

    while time.time() < deadline:
        state = get_telegram_page_state(page)
        print(f"当前 Telegram 页面状态：{state}")

        if state == "restart":
            state = "unknown"

        if state == "logged_in":
            print("状态机检测到已登录，跳过后续 Telegram 登录动作。")
            if not open_telegram_service_chat_guarded(page, reason="状态机检测到已登录，准备确认 #777000", checks_per_round=5, max_refresh_rounds=3, interval_ms=2000):
                restart_count += 1
                if restart_count > max_restarts:
                    raise RuntimeError("已登录但 3 次重新打开后仍无法确认 #777000，不能继续 my.telegram.org 自动流程")
                page = restart_telegram_page_from_scratch(page, label="#777000 确认失败后重新打开")
                handled_phone = False
                handled_code = False
                continue
            mytelegram_done = run_mytelegram_org_flow_after_777000(page, phone)
            break

        if state == "phone":
            if handled_phone:
                next_state = wait_after_phone_submit_transition(
                    page,
                    checks_per_round=12,
                    max_refresh_rounds=3,
                    interval_ms=3000,
                )
                if next_state == "restart":
                    restart_count += 1
                    if restart_count > max_restarts:
                        raise RuntimeError("手机号提交后多次加长等待仍停留在手机号页，已超过重新打开次数")
                    page = restart_telegram_page_from_scratch(page, label="手机号提交卡住后重新打开")
                    handled_phone = False
                    handled_code = False
                    continue
                if next_state == "phone":
                    print("刷新守护后仍是手机号页，重新尝试点击 Next / 确认。")
                    try:
                        click_next_after_phone(page)
                        click_phone_confirm_modal_if_present(page)
                    except Exception as e:
                        print(f"重新点击 Next / 确认失败，继续状态机守护：{e}")
                    page.wait_for_timeout(2000)
                continue

            print("当前是手机号登录页，开始轮询等待真实输入框。")
            fill_phone_number(page, phone, country)
            current_state_after_fill = get_telegram_page_state(page)
            if current_state_after_fill == "phone":
                click_next_after_phone(page)
                click_phone_confirm_modal_if_present(page)
                handled_phone = True
                next_state = wait_after_phone_submit_transition(
                    page,
                    checks_per_round=12,
                    max_refresh_rounds=3,
                    interval_ms=3000,
                )
                if next_state == "restart":
                    restart_count += 1
                    if restart_count > max_restarts:
                        raise RuntimeError("手机号提交后加长等待仍未进入验证码/2FA/已登录，已超过重新打开次数")
                    page = restart_telegram_page_from_scratch(page, label="手机号提交后加长等待失败重新打开")
                    handled_phone = False
                    handled_code = False
            else:
                print(f"手机号填写前后页面已切换为：{current_state_after_fill}，重新进入状态机识别。")
            continue

        if state == "code":
            if is_phone_login_page(page):
                print("当前仍是手机号输入页，不读取 yanzheng 验证码。")
                continue

            if handled_code:
                print("验证码已提交过，先检查是否进入 2FA/已登录，不立即重复读取 yanzheng。")
                next_state = wait_after_code_submit_transition(
                    page,
                    checks_per_round=5,
                    max_refresh_rounds=3,
                    interval_ms=1500,
                )
                if next_state == "restart":
                    restart_count += 1
                    if restart_count > max_restarts:
                        raise RuntimeError("验证码提交后 3x5 仍未进入 2FA/已登录，已超过重新打开次数")
                    page = restart_telegram_page_from_scratch(page, label="验证码提交卡住后重新打开")
                    handled_phone = False
                    handled_code = False
                    continue
                if next_state == "code" and locate_code_field(page, timeout=1000) is not None:
                    print("验证码页仍可编辑，允许主状态机重新读取一次 yanzheng 验证码。")
                    handled_code = False
                continue

            print("当前是 Telegram 登录验证码页，开始从 yanzheng 网页读取 input#code。")
            next_state = fill_current_code_page(page, yanzheng_url)
            handled_code = True
            if next_state == "restart":
                restart_count += 1
                if restart_count > max_restarts:
                    raise RuntimeError("验证码提交后需要重新打开次数过多")
                page = restart_telegram_page_from_scratch(page, label="验证码提交后重新打开")
                handled_phone = False
                handled_code = False
                continue
            if next_state == "password":
                print("验证码提交后已进入 2FA 页面，下一轮处理 2FA。")
            elif next_state == "logged_in":
                print("验证码提交后已进入 Telegram。")
            page.wait_for_timeout(1000)
            continue

        if state == "password":
            print("当前是 Telegram 2FA 页面，开始从 yanzheng 网页读取 input#pass2fa。")
            next_state = fill_current_password_page(page, yanzheng_url)

            if next_state == "restart":
                restart_count += 1
                if restart_count > max_restarts:
                    raise RuntimeError("2FA 提交后 3x5 仍未确认已登录，已超过重新打开次数")
                page = restart_telegram_page_from_scratch(page, label="2FA 提交卡住后重新打开")
                handled_phone = False
                handled_code = False
                continue

            if next_state == "logged_in":
                print("2FA 后已登录，开始 3x5 守护确认 #777000 并继续 my.telegram.org 流程。")
                mytelegram_done = run_mytelegram_org_flow_after_777000(page, phone)
                break

            print(f"2FA 后尚未确认已登录，当前状态：{next_state}，继续主状态机。")
            page.wait_for_timeout(1000)
            continue

        if state == "phone_entry":
            print("当前是 QR/Login by phone 入口页，点击入口后轮询 10 次等待手机号输入框。")
            click_login_by_phone(page)
            page.wait_for_timeout(1200)
            try:
                phone_field, field_kind = wait_for_phone_input_ready(page, attempts=10, interval_ms=1200)
                if phone_field is not None:
                    fill_field(page, phone_field, split_phone_for_telegram(phone, country)[0], field_kind, "完整手机号")
                    click_next_after_phone(page)
                    click_phone_confirm_modal_if_present(page)
                    handled_phone = True
                    next_state = wait_after_phone_submit_transition(
                        page,
                        checks_per_round=12,
                        max_refresh_rounds=3,
                        interval_ms=3000,
                    )
                    if next_state == "restart":
                        restart_count += 1
                        if restart_count > max_restarts:
                            raise RuntimeError("手机号入口提交后 3x5 仍未进入正确页面，已超过重新打开次数")
                        page = restart_telegram_page_from_scratch(page, label="手机号入口提交后重新打开")
                        handled_phone = False
                        handled_code = False
            except RuntimeError as e:
                print(f"手机号入口轮询失败，继续状态机守护：{e}")
            continue

        if click_login_by_phone(page):
            page.wait_for_timeout(3000)
            continue
        page.wait_for_timeout(1000)
    else:
        raise RuntimeError(f"自动登录流程超时，当前页面文本片段：{safe_page_text(page)}")

    print("-" * 80)
    print("Telegram 登录流程已按当前页面状态自动处理完成。")
    print("my.telegram.org 自动流程状态：" + ("已完成" if mytelegram_done else "未完成或需人工检查"))
    print("-" * 80)
    return mytelegram_done

