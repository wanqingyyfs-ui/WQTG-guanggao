        label_name = "Sign In"
    else:
        form_selectors = [
            "form:has(input#my_login_phone) button[type='submit']",
            "form:has(input#my_login_phone) input[type='submit']",
            "form:has(input#my_login_phone) button.btn-primary",
            "form:has(input#my_login_phone) .btn-primary",
        ]
