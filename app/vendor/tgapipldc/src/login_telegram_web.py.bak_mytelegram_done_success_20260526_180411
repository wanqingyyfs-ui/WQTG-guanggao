    with open(ACCOUNT_PROXY_MAP_FILE, "w", encoding="utf-8-sig", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(rows)

    print(f"已更新 account_proxy_map.csv：{phone} -> {new_exit_ip}")


