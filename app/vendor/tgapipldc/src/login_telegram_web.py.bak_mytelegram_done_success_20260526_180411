    if not open_telegram_service_chat_guarded(telegram_page, reason="my.telegram.org 流程开始前需要确认 #777000", checks_per_round=5, max_refresh_rounds=3, interval_ms=2000):
        print("没有确认 #777000 真实消息 DOM，无法继续 my.telegram.org 流程。")
        return False

    try:
        print("先彻底记录 #777000 当前最新真实消息作为基准，记录完成后才打开 my.telegram.org。")
        before_latest_message = record_stable_777000_baseline(telegram_page, timeout=45000, settle_ms=3000)
        if not snapshot_has_real_message_order(before_latest_message):
            raise RuntimeError(f"#777000 基准消息没有 timestamp/message_id：{format_777000_snapshot(before_latest_message)}")
        print(f"#777000 当前最新真实消息基准：{format_777000_snapshot(before_latest_message)}")
        print("#777000 基准已彻底记录，等待 3 秒后再打开 my.telegram.org。")
        telegram_page.wait_for_timeout(3000)
    except Exception as e:
        set_last_automation_result("mytelegram_failed", f"#777000_baseline_failed: {e}")
        print(f"#777000 最新消息基准记录失败，停止 my.telegram.org 流程：{e}")
        return False

    my_page = telegram_page.context.new_page()
    try:
        mytelegram_page_state = fill_mytelegram_phone_without_submit(my_page, phone)

        if mytelegram_page_state == "logged_in_home":
            api_csv_path = run_mytelegram_api_development_tools_flow(my_page, phone)
            set_last_automation_result("mytelegram_done", f"my.telegram.org 已登录并导出 api_id/api_hash：{api_csv_path}")
            print("my.telegram.org 已登录首页，API 开发工具流程已自动完成。")
            return True

        already_password_page = bool(mytelegram_page_state)
        if not already_password_page:
            try:
                my_page.bring_to_front()
            except Exception:
                pass
            click_mytelegram_submit_button(my_page, "下一个", timeout=15000)
            wait_for_mytelegram_phone_submit_feedback(my_page, timeout=30000)

        print("my.telegram.org 手机号提交/验证码页确认后，等待 3 秒再回到 #777000 检查最新消息。")
        my_page.wait_for_timeout(3000)

        if not open_telegram_service_chat_guarded(telegram_page, reason="提交 my.telegram.org 手机号后重新确认 #777000", checks_per_round=5, max_refresh_rounds=3, interval_ms=2000):
            raise RuntimeError("提交 my.telegram.org 手机号后无法重新确认 #777000 真实消息 DOM")

        code = wait_for_mytelegram_code_from_777000(telegram_page, before_latest_message, timeout=120000)
        signin_status = fill_mytelegram_password_and_login(my_page, code)
        if signin_status == "error":
            raise RuntimeError("my.telegram.org 验证码提交后返回错误，不能继续 API 开发工具流程")
        api_csv_path = run_mytelegram_api_development_tools_flow(my_page, phone)
        set_last_automation_result("mytelegram_done", f"my.telegram.org 已登录并导出 api_id/api_hash：{api_csv_path}")
        print("my.telegram.org 手机号、验证码、API 开发工具流程已自动完成。")
        return True
    except MyTelegramTooManyTriesError as e:
        reason = str(e)
        set_last_automation_result("mytelegram_too_many_tries", reason)
        print(f"my.telegram.org 已提示操作过多，本账号停止后续操作：{reason}")
