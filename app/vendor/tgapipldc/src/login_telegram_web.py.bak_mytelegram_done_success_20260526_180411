def wait_for_mytelegram_phone_submit_feedback(my_page, checks_per_round: int = 5, max_refresh_rounds: int = 3, interval_ms: int = 3000, timeout: int | None = None):
    print(
        f"已提交 my.telegram.org 手机号，开始 3x5 等待验证码输入页；"
