def get_telegram_bootstrap_state(page) -> str:
    """
    启动期只做轻量识别，避免页面还在加载时误入 unknown 状态机。
    返回：ready / loading / blank_or_error
    """
    if is_telegram_blank_or_error_page(page):
        return "blank_or_error"

    state = get_telegram_page_state(page)
    if state != "unknown":
        return "ready"

    text = safe_page_text(page, limit=4000)
    if LOGIN_BY_PHONE_REGEX.search(text or ""):
        return "ready"

    if has_telegram_runtime_container(page):
        return "loading"

    if "web.telegram.org" in (page.url or "") and len((text or "").strip()) >= 20:
        return "loading"

    return "blank_or_error"


def wait_for_telegram_bootstrap(
    page,
    checks_per_round: int | None = None,
    max_refresh_rounds: int | None = None,
    interval_ms: int = 10000,
    max_wait_seconds: int = 90,
) -> bool:
    """
    Telegram Web 首屏加载策略：每次只打开一次，给页面足够时间加载。
    不在同一个首屏页面反复硬刷新，也不快速关闭重开。
    到时间仍不可识别，外层再关闭当前页并重新打开官方原始地址。
    checks_per_round/max_refresh_rounds 只保留兼容旧调用，不再按 3x5 快速轮询。
    """
    effective_interval_ms = max(interval_ms, 10000)
    effective_max_wait_seconds = max(max_wait_seconds, 90)
    deadline = time.time() + effective_max_wait_seconds
    check_index = 1
    last_state = ""

    while time.time() < deadline:
        try:
            bootstrap_state = get_telegram_bootstrap_state(page)
            last_state = bootstrap_state
        except Exception as e:
            last_state = f"page_error: {e}"
            print(f"Telegram Web 首屏检查失败：{e}")
            return False

        if bootstrap_state == "ready":
            print("Telegram Web 页面已进入可识别状态。")
            return True

        remaining_seconds = max(0, int(deadline - time.time()))
        print(
            f"Telegram Web 首屏等待检查 {check_index}，"
            f"启动状态：{bootstrap_state}，剩余约 {remaining_seconds} 秒，当前地址：{page.url}"
        )
        page.wait_for_timeout(effective_interval_ms)
        check_index += 1

    print(f"Telegram Web 首屏加载超时仍不可识别，最后启动状态：{last_state}。")
    return False

def restart_telegram_page_from_scratch(page, label: str = "Telegram Web 重新打开"):
    """
    关闭当前 Telegram 页，新建页面，重新打开官方原始地址。
    每次打开后给足加载时间；超时仍不可识别才交回外层处理。
    """
    context = page.context
    try:
        print(f"{label}：关闭当前页面，重新打开 {TELEGRAM_WEB_URL}。")
        page.close()
    except Exception as e:
        print(f"{label}：关闭当前页面失败，继续新建页面：{e}")

    new_page = context.new_page()
    navigate_with_commit(new_page, TELEGRAM_WEB_URL, label=label, timeout=15000)
    wait_for_telegram_bootstrap(new_page, interval_ms=20000, max_wait_seconds=90)
    return new_page

def open_telegram_web_until_ready(page, max_page_reopens: int = 3):
    """
    打开 Telegram Web 的唯一入口。
    每次尝试只打开一次官方原始地址，然后等待足够加载时间。
    如果到时间仍不可识别，才关闭当前页面并新建页面重新打开。
    """
    current_page = page
    context = page.context
    per_attempt_wait_seconds = 90

    for reopen_index in range(1, max_page_reopens + 1):
        print(f"打开 Telegram Web 页面尝试 {reopen_index}/{max_page_reopens}：{TELEGRAM_WEB_URL}")
        navigate_with_commit(current_page, TELEGRAM_WEB_URL, label="Telegram Web", timeout=15000)

        if wait_for_telegram_bootstrap(
            current_page,
            interval_ms=20000,
            max_wait_seconds=per_attempt_wait_seconds,
        ):
            return current_page

        dump_debug_html(current_page, f"telegram_bootstrap_failed_attempt_{reopen_index}")

        if reopen_index < max_page_reopens:
            try:
                print("Telegram Web 本次加载超时仍不可识别，关闭当前页面后重新打开官方原始地址。")
                current_page.close()
            except Exception as e:
                print(f"关闭 Telegram 当前页面失败，继续新建页面：{e}")
            current_page = context.new_page()

    raise RuntimeError("Telegram Web 多次关闭重开后仍未进入可识别状态，停止本账号流程")

def open_url_with_retry(page, url: str, label: str, attempts: int = 4, wait_ms: int = 4000) -> bool:
    for attempt in range(1, attempts + 1):
        print(f"第 {attempt} 次打开 {label}...")
        navigate_with_commit(page, url, label=label, timeout=15000)

        if label.lower().startswith("telegram"):
            if wait_for_telegram_bootstrap(page, interval_ms=20000, max_wait_seconds=90):
                return True
        else:
            page.wait_for_timeout(wait_ms)
            if not is_telegram_blank_or_error_page(page):
                return True

        if attempt < attempts:
            print(f"{label} 本次加载超时仍不可识别，关闭当前页面重新打开。")
            try:
                context = page.context
                page.close()
                page = context.new_page()
            except Exception as e:
                print(f"{label} 关闭当前页失败，继续下一次打开：{e}")
        else:
            print(f"{label} 多次打开后仍不可识别。")

    return False

def is_qr_login_entry_page(page) -> bool:
    """
    Telegram QR 登录入口页不是手机号输入页。
