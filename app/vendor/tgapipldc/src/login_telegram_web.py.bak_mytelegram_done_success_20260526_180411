    if state != "app_config":
        raise RuntimeError(f"API 开发工具页面状态不正确，无法读取 api_id/api_hash：{state}")

    api_id, api_hash = extract_mytelegram_api_credentials(my_page)
    return write_mytelegram_api_credentials_csv(phone, api_id, api_hash, app_title, app_shortname)

def fill_mytelegram_password_and_login(my_page, password_code: str):
    try:
        my_page.bring_to_front()
    except Exception:
        pass
    assert_mytelegram_not_too_many_tries(my_page, "my.telegram.org 填验证码前检测到限制")
    password_input = my_page.locator("input#my_password").first
    password_input.wait_for(state="visible", timeout=60000)
    password_input.scroll_into_view_if_needed(timeout=5000)
    password_input.fill(password_code, timeout=10000)
    current_value = password_input.input_value(timeout=3000) or ""
    if password_code not in current_value:
        raise RuntimeError(f"my.telegram.org 验证码填写失败，目标={password_code}，当前={current_value}")
    print("已把 #777000 里的验证码填入 my.telegram.org。")
    print("等待 3 秒后再点击 my.telegram.org Sign In 按钮，避免页面还没完成输入态同步。")
    my_page.wait_for_timeout(3000)
    click_mytelegram_submit_button(my_page, "Sign In", timeout=15000)
    return wait_for_mytelegram_signin_feedback(my_page, timeout=30000)



