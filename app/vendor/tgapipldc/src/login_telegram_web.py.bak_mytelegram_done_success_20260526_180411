    )


def get_field_value(locator, kind: str) -> str:
    try:
        if kind == "input":
            return locator.input_value(timeout=2000) or ""
        return locator.evaluate("(el) => el.innerText || el.textContent || ''") or ""
    except Exception:
        return ""


def clear_field(page, locator, kind: str, label: str):
    """先清空目标输入框，再返回当前值。"""
    locator.wait_for(state="visible", timeout=10000)
    locator.scroll_into_view_if_needed(timeout=5000)
    locator.click(timeout=10000)
    page.wait_for_timeout(200)

    try:
        if kind == "input":
            locator.fill("", timeout=5000)
        else:
            locator.fill("", timeout=5000)
    except Exception:
        try:
            page.keyboard.press("Control+A")
            page.keyboard.press("Backspace")
        except Exception:
            pass

    page.wait_for_timeout(300)
    current_value = get_field_value(locator, kind)
    if re.sub(r"\s+", "", current_value):
        print(f"{label} 第一次清空后仍有内容：{current_value}，启用 DOM 清空。")
        locator.evaluate(
            """
            (el) => {
                el.focus();
                if (el.getAttribute('contenteditable') === 'true') {
                    el.innerText = '';
                    el.textContent = '';
                    el.dispatchEvent(new InputEvent('input', {
                        bubbles: true,
                        cancelable: true,
                        inputType: 'deleteContentBackward',
                        data: null
                    }));
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                    return;
                }
                const prototype = el instanceof HTMLTextAreaElement
                    ? HTMLTextAreaElement.prototype
                    : HTMLInputElement.prototype;
                const descriptor = Object.getOwnPropertyDescriptor(prototype, 'value');
                if (descriptor && descriptor.set) descriptor.set.call(el, '');
                else el.value = '';
                el.dispatchEvent(new InputEvent('input', {
                    bubbles: true,
                    cancelable: true,
                    inputType: 'deleteContentBackward',
                    data: null
                }));
                el.dispatchEvent(new Event('change', { bubbles: true }));
            }
            """
        )
        page.wait_for_timeout(300)

    current_value = get_field_value(locator, kind)
    print(f"{label} 清空后当前值：{current_value}")
    return current_value


def fill_field(page, locator, value: str, kind: str, label: str):
    """按官方 Locator/键盘流程填写：定位目标框 -> 清空 -> 输入 -> 校验 -> 必要时 DOM 兜底。"""
    clean_target = re.sub(r"\D", "", value)

    clear_field(page, locator, kind, label)

    locator.click(timeout=10000)
    page.wait_for_timeout(200)

    typed = False
    try:
        if kind == "input":
            locator.fill(value, timeout=10000)
        else:
            page.keyboard.insert_text(value)
        typed = True
    except Exception as e:
        print(f"{label} 常规输入失败，准备兜底：{e}")

    page.wait_for_timeout(700)
    current_value = get_field_value(locator, kind)
    clean_current = re.sub(r"\D", "", current_value)

    if not typed or (clean_target and clean_target not in clean_current):
        print(f"{label} 常规输入未通过校验，启用 DOM 强制写入。目标={value}，当前={current_value}")
        locator.evaluate(
            """
            (el, value) => {
                el.focus();
                if (el.getAttribute('contenteditable') === 'true') {
                    el.innerText = '';
                    el.textContent = '';
                    el.dispatchEvent(new InputEvent('input', {
                        bubbles: true,
                        cancelable: true,
                        inputType: 'deleteContentBackward',
                        data: null
                    }));
                    document.execCommand('insertText', false, value);
                    if ((el.innerText || el.textContent || '').replace(/\D/g, '') !== value.replace(/\D/g, '')) {
                        el.innerText = value;
                        el.textContent = value;
                    }
                    el.dispatchEvent(new InputEvent('input', {
                        bubbles: true,
                        cancelable: true,
                        inputType: 'insertText',
                        data: value
                    }));
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                    el.dispatchEvent(new KeyboardEvent('keyup', { bubbles: true, key: '0', code: 'Digit0' }));
                    return;
                }

                const prototype = el instanceof HTMLTextAreaElement
                    ? HTMLTextAreaElement.prototype
                    : HTMLInputElement.prototype;
                const descriptor = Object.getOwnPropertyDescriptor(prototype, 'value');
                if (descriptor && descriptor.set) descriptor.set.call(el, value);
                else el.value = value;
                el.dispatchEvent(new InputEvent('input', {
                    bubbles: true,
                    cancelable: true,
                    inputType: 'insertText',
                    data: value
                }));
                el.dispatchEvent(new Event('change', { bubbles: true }));
            }
            """,
            value,
        )
        page.wait_for_timeout(700)

    current_value = get_field_value(locator, kind)
    print(f"{label} 输入框当前值：{current_value}")
    clean_current = re.sub(r"\D", "", current_value)
    if clean_target and clean_target not in clean_current:
        dump_debug_html(page, "telegram_phone_fill_failed")
        raise RuntimeError(f"{label} 写入失败。目标={value}，当前={current_value}")

def fill_phone_number(page, phone: str, country: str = ""):
    telegram_phone, country_code, national_number = split_phone_for_telegram(phone, country)
    print(f"准备填写手机号：{telegram_phone}")
    print(f"国家码：{country_code or '不单独填写'}")
