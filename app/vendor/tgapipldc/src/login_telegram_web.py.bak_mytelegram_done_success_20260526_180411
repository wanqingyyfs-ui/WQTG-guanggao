def visible_from_selector(page, selector: str, timeout: int = 800):
    locator = page.locator(selector)
    try:
        count = locator.count()
    except Exception:
        return None
    for index in range(count):
        item = locator.nth(index)
        try:
            if item.is_visible(timeout=timeout):
                return item
        except Exception:
            continue
    return None


def is_locator_enabled_for_input(locator, timeout: int = 500) -> bool:
    """只把真正可编辑的输入框交给填写逻辑，避免 Telegram 转圈时填 disabled OTP 框。"""
    try:
        if not locator.is_visible(timeout=timeout):
            return False
    except Exception:
        return False

    try:
        info = locator.evaluate(
            """
            (el) => ({
                disabled: Boolean(el.disabled),
                readOnly: Boolean(el.readOnly),
                ariaDisabled: el.getAttribute('aria-disabled') || '',
                contenteditable: el.getAttribute('contenteditable') || '',
                className: el.getAttribute('class') || '',
                tabindex: el.getAttribute('tabindex') || ''
            })
            """
        )
    except Exception:
        info = {}

    if info.get("disabled") or info.get("readOnly"):
        return False
    if str(info.get("ariaDisabled") or "").lower() == "true":
        return False
    if "stealthy" in str(info.get("className") or ""):
        return False
    if str(info.get("tabindex") or "") == "-1":
        return False

    try:
        return bool(locator.is_enabled(timeout=timeout))
    except Exception:
        return str(info.get("contenteditable") or "").lower() == "true"


def visible_code_input_exists(page, timeout: int = 500) -> bool:
    selectors = [
        "input[inputmode='numeric']:not(.stealthy):not([tabindex='-1'])",
        "input[inputmode='decimal']:not(.stealthy):not([tabindex='-1'])",
        "input[autocomplete='one-time-code']:not(.stealthy):not([tabindex='-1'])",
        "input[type='tel']:not(.stealthy):not([tabindex='-1'])",
        "input[type='text']:not(.stealthy):not([tabindex='-1'])",
        "div.input-field-input[contenteditable='true'][inputmode='numeric']",
        "div.input-field-input[contenteditable='true'][inputmode='decimal']",
        "div[contenteditable='true'][inputmode='numeric']",
        "div[contenteditable='true'][inputmode='decimal']",
    ]
    for selector in selectors:
        item = visible_from_selector(page, selector, timeout=timeout)
        if item is not None and not is_phone_context(item):
            return True
    return False


def locate_code_field(page, timeout: int = 30000):
    if is_phone_login_page(page):
        return None

    selectors = [
        "input[autocomplete='one-time-code']:not(.stealthy):not([tabindex='-1'])",
        "input[inputmode='numeric']:not(.stealthy):not([tabindex='-1'])",
        "input[inputmode='decimal']:not(.stealthy):not([tabindex='-1'])",
        "input[type='tel']:not(.stealthy):not([tabindex='-1'])",
        "input[type='text']:not(.stealthy):not([tabindex='-1'])",
        "div.input-field-input[contenteditable='true'][inputmode='numeric']",
        "div.input-field-input[contenteditable='true'][inputmode='decimal']",
        "div[contenteditable='true'][inputmode='numeric']",
        "div[contenteditable='true'][inputmode='decimal']",
    ]

    deadline = time.time() + timeout / 1000
    last_disabled_seen = False
    while time.time() < deadline:
        if is_phone_screen_by_text(page):
            return None
        for selector in selectors:
            locator = page.locator(selector)
            try:
                count = locator.count()
            except Exception:
                continue
            for index in range(count):
                item = locator.nth(index)
                try:
                    if not item.is_visible(timeout=500):
                        continue
                    if is_phone_context(item):
                        continue
                    if is_locator_enabled_for_input(item, timeout=500):
                        return item
                    last_disabled_seen = True
                except Exception:
                    continue
        if last_disabled_seen:
            print("验证码输入框已出现但暂不可编辑，等待 Telegram 页面完成跳转/渲染。")
            last_disabled_seen = False
        page.wait_for_timeout(700)
    return None


def locate_password_field(page, timeout: int = 15000):
    selectors = [
        "input.input-field-input[name='notsearch_password']:not(.stealthy):not([tabindex='-1'])",
        "input[name='notsearch_password']:not(.stealthy):not([tabindex='-1'])",
        "input.input-field-input[type='password']:not(.stealthy):not([tabindex='-1'])",
        "input[type='password']:not(.stealthy):not([tabindex='-1'])",
        "input[name*='password' i]:not(.stealthy):not([tabindex='-1'])",
        "input[autocomplete='current-password']:not(.stealthy):not([tabindex='-1'])",
    ]
    deadline = time.time() + timeout / 1000
    while time.time() < deadline:
        for selector in selectors:
            item = visible_from_selector(page, selector, timeout=500)
            if item is not None:
                return item
        page.wait_for_timeout(500)
    return None



def is_telegram_logged_in_page(page, timeout: int = 700) -> bool:
    """
    只按 Telegram Web 已登录后的真实 DOM 判断登录状态。

    不能因为 URL 带 #777000 或页面出现 Telegram 字样就判定已登录；
    登录入口页、手机号页、验证码页、2FA 页必须排除在外。
    """
    text = safe_page_text(page, limit=3000)
    lowered = text.lower()

    if (
        "sign in to telegram" in lowered
        or "log in to telegram" in lowered
        or "please confirm your country code" in lowered
        or "confirm your country code" in lowered
    ):
        return False

    phone_login_like = (
        "phone number" in lowered
        and ("country code" in lowered or re.search(r"(^|\n|\r)\s*next\s*($|\n|\r)", lowered, re.IGNORECASE))
    )
    if phone_login_like:
        return False

    try:
        phone_field, _ = locate_phone_field(page, timeout=250)
        if phone_field is not None:
            return False
    except Exception:
        pass

    try:
        if locate_password_field(page, timeout=250) is not None:
            return False
    except Exception:
        pass

    logged_in_selectors = [
        "a.chatlist-chat[data-peer-id]",
        "a.row.chatlist-chat[href^='#'][data-peer-id]",
        "a[href^='#'][data-peer-id]",
        ".input-message-container",
        ".input-message-input",
        "[contenteditable='true'][data-placeholder*='Message' i]",
        "[contenteditable='true'][aria-label*='Message' i]",
        "div.bubble[data-peer-id][data-mid][data-timestamp]",
    ]
    for selector in logged_in_selectors:
        if visible_from_selector(page, selector, timeout=timeout) is not None:
            return True

    if re.search(r"(^|\n|\r)\s*(all chats|saved messages|archived chats)\s*($|\n|\r)", lowered, re.IGNORECASE):
        return True

    return False


def get_telegram_page_state(page) -> str:
    """
    Telegram 页面状态识别顺序：
    1. logged_in：已登录聊天界面，最高优先级
    2. phone：手机号输入页面
    3. code：Telegram 登录验证码页面
    4. password：Telegram 2FA 页面
    5. phone_entry：Login by phone / Login iPhone / QR 入口页
    6. blank_or_error：空白或浏览器错误页
    7. unknown：加载中或无法识别
    """
    text = safe_page_text(page, limit=4000)
    lowered = text.lower()

    if is_telegram_logged_in_page(page, timeout=500):
        return "logged_in"

    if is_phone_screen_by_text(page) or is_phone_login_page(page):
        return "phone"

    code_regex = re.compile(r"(verification|sent.*code|enter.*code|login code|验证码|登录码|確認コード|認証コード)", re.IGNORECASE)
    code_field = locate_code_field(page, timeout=700)
    if code_field is not None and (code_regex.search(text or "") or "phone number" not in lowered):
        return "code"
    if code_regex.search(text or "") and visible_code_input_exists(page, timeout=500):
        return "code"

    if locate_password_field(page, timeout=700) is not None:
        return "password"

    password_regex = re.compile(r"(password|two-step|two step|two-factor|two factor|2fa|密码|二步|两步)", re.IGNORECASE)
    if password_regex.search(text or "") and locate_password_field(page, timeout=700) is not None:
        return "password"

    # QR 登录页上有 LOG IN BY PHONE NUMBER 按钮，但还不是手机号输入页。
    if is_qr_login_entry_page(page) or LOGIN_BY_PHONE_REGEX.search(text or ""):
        if not is_phone_screen_by_text(page) and locate_phone_field(page, timeout=400)[0] is None:
            return "phone_entry"

    try:
        if is_telegram_blank_or_error_page(page):
            return "blank_or_error"
    except Exception:
        pass

    return "unknown"

def extract_yanzheng_input_value(html_text: str, input_id: str) -> str:
    pattern = re.compile(
        rf"<input\b(?=[^>]*\bid=[\"']{re.escape(input_id)}[\"'])[^>]*\bvalue=([\"'])(.*?)\1",
        re.IGNORECASE | re.DOTALL,
    )
    match = pattern.search(html_text or "")
    if not match:
        return ""
    return unescape(match.group(2)).strip()


def fetch_yanzheng_html(yanzheng_url: str, timeout: int = 20) -> str:
    if not yanzheng_url:
        raise ValueError("当前账号缺少 yanzheng 验证码网页地址")
    response = requests.get(
        yanzheng_url,
        timeout=timeout,
        headers={
            "User-Agent": "Mozilla/5.0 TelegramLoginHelper/1.0",
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        },
    )
    response.raise_for_status()
    return response.text


def wait_for_yanzheng_value(yanzheng_url: str, input_id: str, label: str, timeout_seconds: int = 120) -> str:
    print(f"正在从验证码网页读取 {label}：input#{input_id}")
    deadline = time.time() + timeout_seconds
    last_error = ""
    while time.time() < deadline:
        try:
            value = extract_yanzheng_input_value(fetch_yanzheng_html(yanzheng_url), input_id)
            if value:
                print(f"已读取到 {label}。")
                return value
            last_error = f"input#{input_id} 为空或不存在"
        except Exception as e:
            last_error = str(e)
        print(f"暂未读取到 {label}，2 秒后重试。原因：{last_error}")
        time.sleep(2)
    raise TimeoutError(f"等待 {label} 超时：{last_error}")


def fill_telegram_text_field(page, locator, value: str, label: str):
    if locator is None:
        raise RuntimeError(f"未找到 Telegram {label} 输入框")
    locator.wait_for(state="visible", timeout=10000)
    locator.scroll_into_view_if_needed(timeout=5000)

    try:
        tag_info = locator.evaluate(
            """
            (el) => ({
                contenteditable: el.getAttribute('contenteditable') || '',
                className: el.getAttribute('class') || '',
                tabindex: el.getAttribute('tabindex') || ''
            })
            """
        )
    except Exception:
        tag_info = {"contenteditable": "", "className": "", "tabindex": ""}

    if "stealthy" in (tag_info.get("className") or "") or (tag_info.get("tabindex") or "") == "-1":
        raise RuntimeError(f"定位到的是 Telegram 隐藏输入框，不允许填写：{label}")

    kind = "contenteditable" if (tag_info.get("contenteditable") or "").lower() == "true" else "input"
    fill_field(page, locator, value, kind, label)
    print(f"已填写 Telegram {label}。")


