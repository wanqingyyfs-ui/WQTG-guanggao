def detect_exit_ip_by_requests(parsed_proxy, timeout: int = 30) -> tuple[bool, str, str]:
    last_error = ""
    for url in IP_CHECK_URLS:
        try:
            response = requests.get(url, proxies=parsed_proxy.requests_proxies, timeout=timeout)
            response.raise_for_status()
            data = response.json()
            exit_ip = data.get("ip")
            if exit_ip:
                return True, exit_ip, ""
            last_error = f"{url} 返回中没有 ip 字段"
        except Exception as e:
            last_error = str(e)
    return False, "", last_error


def detect_exit_ip_by_browser(page, timeout: int = 60000) -> tuple[bool, str, str]:
    last_error = ""
    for url in IP_CHECK_URLS:
        try:
            page.goto(url, wait_until="domcontentloaded", timeout=timeout)
            body_text = page.inner_text("body").strip()
            try:
                data = json.loads(body_text)
            except json.JSONDecodeError:
                last_error = f"{url} 返回不是 JSON：{body_text[:200]}"
                continue
            exit_ip = data.get("ip")
            if exit_ip:
                return True, exit_ip, ""
            last_error = f"{url} 返回中没有 ip 字段"
        except Exception as e:
            last_error = str(e)
    return False, "", last_error


