    text = safe_page_text(page, limit=4000)
    lowered = text.lower()
    if not lowered:
        return False

    has_qr_login_text = (
        "log in to telegram by qr code" in lowered
        or "open telegram on your phone" in lowered
        or "link desktop device" in lowered
        or "point your phone at this screen" in lowered
    )
    has_phone_entry_button = re.search(
        r"(log\s*in\s*by\s*phone\s*number|login\s*by\s*phone\s*number|use\s*phone\s*number)",
        text or "",
        re.IGNORECASE,
    ) is not None
    return bool(has_qr_login_text and has_phone_entry_button)


def is_phone_screen_by_text(page) -> bool:
    text = safe_page_text(page, limit=4000)
    lowered = text.lower()
    if not lowered:
        return False

    if is_qr_login_entry_page(page):
        return False

    has_title = "sign in to telegram" in lowered or "log in to telegram" in lowered
    has_phone = "phone number" in lowered or "手机号" in text or "电话号码" in text
    has_country = "country code" in lowered or "confirm your country code" in lowered or "country" in lowered or "国家" in text
    has_next = bool(re.search(r"(^|\n|\r)\s*(next|下一步|继续)\s*($|\n|\r)", lowered, re.IGNORECASE))

    # 只有出现国家码/Next/真实输入框语义时，才算手机号输入页；
    # 单独出现 LOG IN BY PHONE NUMBER 按钮不算。
    return bool(has_phone and (has_country or has_next or (has_title and "country" in lowered)))


def wait_for_phone_input_ready(page, attempts: int = 10, interval_ms: int = 1000):
    """点击手机号入口后，连续轮询等待真实手机号输入框出现。"""
    last_state = "unknown"
    last_snapshot = ""

    for attempt in range(1, attempts + 1):
        state = get_telegram_page_state(page)
        last_state = state
        last_snapshot = safe_page_text(page, limit=1200)
        print(f"手机号输入框轮询 {attempt}/{attempts}，当前状态：{state}")

        if state == "phone_entry":
            click_login_by_phone(page)
            page.wait_for_timeout(interval_ms)
            continue

        if state == "phone":
            phone_field, field_kind = locate_phone_field(page, timeout=1200)
            if phone_field is not None:
                print("已轮询检测到真实手机号输入框。")
                return phone_field, field_kind

        if state in {"code", "password", "logged_in"}:
            return None, state

        page.wait_for_timeout(interval_ms)

    dump_debug_html(page, "telegram_phone_field_poll_timeout")
    raise RuntimeError(
        "连续轮询 10 次仍未找到 Telegram 手机号输入框。"
        f"最后状态={last_state}，当前页面文本片段：{last_snapshot}"
    )


def wait_after_phone_submit_transition(
    page,
    checks_per_round: int = 12,
    max_refresh_rounds: int = 3,
    interval_ms: int = 6000,
) -> str:
    """
    手机号提交后加长守护：每轮检查 12 次；未离开 phone 才硬刷新。
    3 轮仍然停留在 phone，返回 restart，让主流程关闭当前页面并重新打开 Telegram Web 从头识别。
    """
    print(
        f"手机号已提交，开始加长等待页面跳转；每轮检查 {checks_per_round} 次，"
        f"每次间隔 {interval_ms // 1000} 秒，最多 {max_refresh_rounds} 轮；仍不正确才关闭页面重新打开 Telegram Web。"
    )

    last_state = "unknown"

    for refresh_round in range(1, max_refresh_rounds + 1):
        for check_index in range(1, checks_per_round + 1):
            state = get_telegram_page_state(page)
            last_state = state
            print(
                f"手机号提交后状态检查：轮次 {refresh_round}/{max_refresh_rounds}，"
                f"检查 {check_index}/{checks_per_round}，当前状态：{state}"
            )

            if state != "phone":
                print(f"手机号提交后页面已离开手机号页，当前状态：{state}")
                return state

            page.wait_for_timeout(interval_ms)

        if refresh_round < max_refresh_rounds:
            print("本轮多次检查仍停留在手机号页，执行 Telegram Web 硬刷新。")
            hard_refresh_telegram_page(page, TELEGRAM_WEB_URL, label="Telegram Web 手机号提交后", wait_ms=7000)

    print(f"加长等待后仍未离开手机号页，需要关闭当前页面重新打开 Telegram Web。最后状态：{last_state}")
    return "restart"

def _field_score(info: dict[str, Any]) -> int:
    """给 Telegram 手机号输入框候选项打分。

    目标是找“Phone Number”本地号码框，不是 Country/Country Code 框。
    Telegram Web 的 DOM 会变化，所以这里只依赖稳定语义：label、closest input-field、aria、placeholder、inputmode。
    """
    label_text = str(info.get("label_text") or "").lower()
    aria = str(info.get("aria") or "").lower()
    placeholder = str(info.get("placeholder") or "").lower()
    wrapper_text = str(info.get("wrapper_text") or "").lower()
    row_text = str(info.get("row_text") or "").lower()
    parent_text = str(info.get("parent_text") or "").lower()
    form_text = str(info.get("form_text") or "").lower()
    outer_html = str(info.get("outer_html") or "").lower()
    class_name = str(info.get("class_name") or "").lower()
    input_field_class = str(info.get("input_field_class") or "").lower()
    tag = str(info.get("tag") or "").lower()
    input_type = str(info.get("type") or "").lower()
    input_mode = str(info.get("input_mode") or "").lower()
    contenteditable = str(info.get("contenteditable") or "").lower()
    own_text = str(info.get("own_text") or "").strip()
    own_digits = re.sub(r"\D", "", own_text)

    direct_text = " ".join([label_text, aria, placeholder, input_field_class, class_name])
    near_text = " ".join([label_text, aria, placeholder, wrapper_text, row_text, parent_text])
    all_text = " ".join([near_text, form_text, outer_html])

    phone_label = bool(re.search(r"(phone\s*number|phone-number|手机号|手机号码|电话号码)", direct_text))
    phone_near = bool(re.search(r"(phone\s*number|phone-number|手机号|手机号码|电话号码)", near_text))
    country_label = bool(re.search(r"(country\s*code|country|国家|区号)", direct_text))
    country_near = bool(re.search(r"(country\s*code|country|国家|区号)", near_text))

    score = 0

    if "input-field-input" in class_name:
        score += 40
    if contenteditable == "true":
        score += 40
    if tag == "input" and input_type in {"tel", "text", "number"}:
        score += 70
    if input_mode in {"decimal", "numeric", "tel"}:
        score += 60

    if phone_label:
        score += 500
    elif phone_near:
        score += 260
    elif "phone" in all_text:
        score += 70

    if "sign in to telegram" in all_text and ("phone" in all_text or "country" in all_text):
        score += 30

    # Country/Country Code 字段必须强惩罚。即使它已经被旧版本误填成长号码，也不能继续选它。
    if country_label and not phone_label:
        score -= 650
    elif country_near and not phone_near:
        score -= 350
    elif country_near and phone_near:
        score -= 80

    if re.search(r"(^|\s)\+?\d{1,4}(\s|$)", own_text) and len(own_digits) <= 4:
        score -= 180

    if len(own_digits) >= 8 and not country_label:
        score += 20

    if "password" in all_text or "code" in direct_text:
        score -= 500

    return score


def locate_phone_field(page, timeout: int = 1500):
    """定位真实手机号输入框。

    先使用 Playwright Locator 逐个检查候选，再按 Telegram 当前 DOM 语义打分。
    返回前会打印命中的 label/wrapper，方便继续判断是否选错。
    """
    selectors = [
        ".input-field:has-text('Phone Number') .input-field-input[contenteditable='true']",
        ".input-field:has-text('phone number') .input-field-input[contenteditable='true']",
        ".input-field:has-text('Phone') .input-field-input[contenteditable='true']",
        "div.input-field-input[contenteditable='true'][inputmode='decimal']",
        "div.input-field-input[contenteditable='true'][inputmode='numeric']",
        ".input-field-input[contenteditable='true']",
        "[contenteditable='true'][inputmode='decimal']",
        "[contenteditable='true'][inputmode='numeric']",
        "input[type='tel']",
        "input[name*='phone' i]",
        "input[aria-label*='phone' i]",
        "input[placeholder*='phone' i]",
        "input.input-field-input:not([type='password']):not(.stealthy):not([tabindex='-1'])",
    ]

    best = None
    best_kind = ""
    best_score = -9999
    best_selector = ""
    best_index = -1
    best_info: dict[str, Any] = {}

    for selector in selectors:
        locator = page.locator(selector)
        try:
            count = locator.count()
        except Exception:
            continue

        for index in range(count):
            item = locator.nth(index)
            try:
                if not item.is_visible(timeout=timeout):
                    continue

                info = item.evaluate(
                    """
                    (el) => {
                        const inputField = el.closest('.input-field');
                        const row = el.closest('.row');
                        const form = el.closest('form');
                        const parent = el.parentElement;
                        const previous = parent ? parent.previousElementSibling : null;
                        const next = parent ? parent.nextElementSibling : null;
                        const labelCandidates = [
                            inputField ? inputField.querySelector('.input-field-label') : null,
                            inputField ? inputField.querySelector('label') : null,
                            inputField ? inputField.querySelector('[class*="label"]') : null,
                            previous,
                        ].filter(Boolean);
                        const labelText = labelCandidates.map((node) => node.innerText || node.textContent || '').join(' ');
                        return {
                            tag: (el.tagName || '').toLowerCase(),
                            type: el.getAttribute('type') || '',
                            id: el.getAttribute('id') || '',
                            name: el.getAttribute('name') || '',
                            class_name: el.getAttribute('class') || '',
                            input_field_class: inputField ? (inputField.getAttribute('class') || '') : '',
                            input_mode: el.getAttribute('inputmode') || '',
                            contenteditable: el.getAttribute('contenteditable') || '',
                            aria: el.getAttribute('aria-label') || '',
                            placeholder: el.getAttribute('placeholder') || '',
                            data_left_pattern: el.getAttribute('data-left-pattern') || '',
                            own_text: el.innerText || el.textContent || el.value || '',
                            label_text: labelText,
                            wrapper_text: inputField ? (inputField.innerText || inputField.textContent || '') : '',
                            row_text: row ? (row.innerText || row.textContent || '') : '',
                            parent_text: parent ? (parent.innerText || parent.textContent || '') : '',
                            previous_text: previous ? (previous.innerText || previous.textContent || '') : '',
                            next_text: next ? (next.innerText || next.textContent || '') : '',
                            form_text: form ? (form.innerText || form.textContent || '') : '',
                            outer_html: el.outerHTML || '',
                        };
                    }
                    """
                )

                score = _field_score(info)
                if score > best_score or (score == best_score and index > best_index):
                    best = item
                    best_kind = "contenteditable" if str(info.get("contenteditable") or "").lower() == "true" else "input"
                    best_score = score
                    best_selector = selector
                    best_index = index
                    best_info = info
            except Exception:
                continue

    if best is not None and best_score >= 120:
        label_text = re.sub(r"\s+", " ", str(best_info.get("label_text") or "")).strip()
        wrapper_text = re.sub(r"\s+", " ", str(best_info.get("wrapper_text") or "")).strip()
        print(
            f"已定位 Telegram 手机号输入框：kind={best_kind}, selector={best_selector}, "
            f"index={best_index}, score={best_score}, label={label_text[:80]}, wrapper={wrapper_text[:120]}"
        )
        return best, best_kind

    return None, ""

def is_phone_login_page(page) -> bool:
    text = safe_page_text(page, limit=3500)
    lowered = text.lower()

    if re.search(r"(verification|sent.*code|enter.*code|login code|验证码|登录码|確認コード|認証コード)", text or "", re.IGNORECASE):
        if "phone number" not in lowered and "country code" not in lowered:
            return False

    if re.search(r"(password|two-step|two step|two-factor|two factor|2fa|密码|二步|两步)", text or "", re.IGNORECASE):
        return False

    if is_phone_screen_by_text(page):
        return True

    field, _ = locate_phone_field(page, timeout=700)
    return field is not None


def click_login_by_phone(page) -> bool:
    print("正在检测当前页面是否已经可以输入手机号...")
    if is_phone_login_page(page):
        print("当前已经是手机号输入页，不需要点击登录入口。")
        return True

    print("正在查找 Login iPhone / 手机号登录入口...")
