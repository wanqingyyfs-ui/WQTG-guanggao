def normalize_candidate_code(raw_code: str) -> str:
    """
    保留验证码主体里的所有符号字符。
    只清理不可见字符、首尾空白、首尾包裹引号/括号。
    不再把 _、-、&、*、!、#、%、@、$ 等符号截断。
    """
    code = unescape(raw_code or "")
    code = code.replace("\u200b", "").replace("\u200c", "").replace("\u200d", "")
    code = code.strip()

    wrapping_pairs = [
        ('"', '"'),
        ("'", "'"),
        ("`", "`"),
        ("“", "”"),
        ("‘", "’"),
        ("(", ")"),
        ("[", "]"),
        ("{", "}"),
        ("<", ">"),
    ]

    changed = True
    while changed and len(code) >= 2:
        changed = False
        for left, right in wrapping_pairs:
            if code.startswith(left) and code.endswith(right):
                code = code[1:-1].strip()
                changed = True

    # Telegram 常见纯数字码后面会跟英文句号：Login code: 91906. Do not...
    # 这里只处理纯数字验证码后面被句子句号粘住的情况；带符号验证码不删符号。
    if re.fullmatch(r"\d{5,8}\.", code):
        code = code[:-1]

    return code


def is_valid_candidate_code(code: str) -> bool:
    """
    验证码允许包含任意非空白字符，包括：
    _ - & * ! # % @ $ ^ = + : . , ? / \\ ~ 等。
    """
    if not code:
        return False
    if len(code) < 4 or len(code) > 128:
        return False
    if re.search(r"\s", code):
        return False

    lowered = code.lower()
    blocked_exact = {
        "code", "login", "password", "telegram", "my.telegram.org", "https", "http", "www",
        "from", "this", "your", "verification", "confirmation", "attempt", "account",
        "website", "browser", "message", "messages", "copied", "clipboard", "copy",
        "button", "sign", "next", "signin",
    }

    if lowered in blocked_exact:
        return False
    if lowered.startswith("http") or "://" in lowered:
        return False
    if re.fullmatch(r"[\u4e00-\u9fff]+", code):
        return False

    has_digit = bool(re.search(r"\d", code))
    has_upper = bool(re.search(r"[A-Z]", code))
    has_lower = bool(re.search(r"[a-z]", code))
    has_symbol = bool(re.search(r"[^A-Za-z0-9]", code))

    if has_digit:
        return True
    if has_symbol and (has_upper or has_lower or len(code) >= 4):
        return True
    if has_upper and has_lower and len(code) >= 6:
        return True

    return False


def extract_candidate_codes_from_text(text: str) -> list[str]:
    """
    从 #777000 消息里提取验证码。

    核心规则：
    - 明确匹配 login code / confirmation code / verification code 后面的完整非空白字符串；
    - 不限制为字母数字；
    - 保留验证码里的所有符号；
    - cRSvs6_F53g 会完整返回 cRSvs6_F53g；
    - abc&*!#*%%XYZ 会完整返回 abc&*!#*%%XYZ。
    """
    text = unescape(text or "")
    text = text.replace("\u200b", "").replace("\u200c", "").replace("\u200d", "")

    candidates: list[str] = []

    def append(raw: str):
        code = normalize_candidate_code(raw)
        if is_valid_candidate_code(code) and code not in candidates:
            candidates.append(code)

    full_token = r"([^\s]+)"

    priority_patterns = [
        rf"(?:this\s+is\s+your\s+login\s+code|your\s+login\s+code|login\s+code)\s*[:：]\s*{full_token}",
        rf"(?:this\s+is\s+your\s+confirmation\s+code|your\s+confirmation\s+code|confirmation\s+code)\s*[:：]\s*{full_token}",
        rf"(?:this\s+is\s+your\s+verification\s+code|your\s+verification\s+code|verification\s+code)\s*[:：]\s*{full_token}",
        rf"(?:my\.telegram\.org\s+code|my\.telegram\.org\s+login\s+code)\s*[:：]\s*{full_token}",
        rf"(?:验证码|登录码|登入码|確認碼|驗證碼|代碼|コード)\s*[:：]\s*{full_token}",
    ]

    for pattern in priority_patterns:
        for match in re.finditer(pattern, text, re.IGNORECASE):
            append(match.group(1))
        if candidates:
            return candidates

    code_label = r"(?:login\s*code|verification\s*code|confirmation\s*code|my\.telegram\.org\s*code|code|password|验证码|登录码|登入码|確認碼|驗證碼|代碼|コード)"
    secondary_patterns = [
        rf"{code_label}[^\S\r\n]*[:：]?[^\S\r\n]*{full_token}",
        rf"{code_label}[\s\S]{{0,160}}?{full_token}",
        rf"[`'\"“”‘’]([^\s`'\"“”‘’]{{4,128}})[`'\"“”‘’]",
        r"\b(\d{5,8})\b",
    ]

    for pattern in secondary_patterns:
        for match in re.finditer(pattern, text, re.IGNORECASE):
            append(match.group(1))
        if candidates:
            return candidates

    return candidates
# ===== mytelegram code full-symbol override v8 end =====


def wait_for_mytelegram_code_from_777000(page, before_latest_message: dict[str, str], timeout: int = 120000) -> str:
    """
    回到 #777000 后读取 my.telegram.org 验证码。

    主判断：timestamp/message_id 递增。
    兜底判断：如果 Telegram 当前版本没有暴露数值 timestamp/mid，只有在最新真实消息文本能提取到验证码时，
    才允许用 key 变化作为兜底，避免普通重渲染误判。
    """
    print("回到 Telegram #777000 页面，按当前聊天窗口最新消息变化读取 my.telegram.org 登录验证码...")
    baseline = normalize_777000_snapshot(before_latest_message)
    if not snapshot_has_real_message_order(baseline):
        raise RuntimeError(f"#777000 基准消息不可用，不能继续等待验证码：{format_777000_snapshot(baseline)}")

    baseline_order = snapshot_to_order(baseline)
    baseline_key = baseline.get("key") or ""
    latest_seen = baseline
    print(f"#777000 基准已记录：{format_777000_snapshot(baseline)}")

    deadline = time.time() + timeout / 1000
    attempt = 1
    while time.time() < deadline:
        if "#777000" not in (page.url or ""):
            open_telegram_service_chat(page, timeout=30000)

        snapshot = get_latest_777000_message_snapshot(page, allow_chatlist_fallback=False)
        normalized = normalize_777000_snapshot(snapshot)

        if snapshot_has_real_message_order(normalized):
            latest_seen = normalized
            latest_order = snapshot_to_order(normalized)
            latest_key = normalized.get("key") or ""
            latest_text = normalized.get("text") or ""
            codes = extract_candidate_codes_from_text(latest_text)

            numeric_baseline = baseline_order[0] > 0 or baseline_order[1] > 0
            numeric_latest = latest_order[0] > 0 or latest_order[1] > 0

            if numeric_baseline and numeric_latest and latest_order[:2] > baseline_order[:2]:
                print("检测到 #777000 最新消息 timestamp/message_id 已更新，开始提取验证码。")
                print(f"#777000 新消息：{format_777000_snapshot(normalized)}")
                if codes:
                    code = codes[-1]
                    print(f"已从 #777000 新消息读取到 my.telegram.org 验证码：{code}")
                    return code
                print("新消息已更新，但暂未提取到可用验证码；不更新基准，继续等待该消息完整渲染或下一条新消息。")

            elif (not numeric_baseline or not numeric_latest) and latest_key and latest_key != baseline_key:
                if codes:
                    print("检测到 #777000 当前聊天窗口最新消息变化，并从文本中提取到验证码。")
                    print(f"#777000 新消息：{format_777000_snapshot(normalized)}")
                    code = codes[-1]
                    print(f"已从 #777000 新消息读取到 my.telegram.org 验证码：{code}")
                    return code
                print("#777000 最新消息 key 有变化，但暂未提取到可用验证码；不更新基准，继续等待。")

        elif attempt % 3 == 0:
            print("#777000 当前聊天窗口消息暂未渲染，刷新后继续等待。")
            safe_reload_or_goto(page, TELEGRAM_SERVICE_CHAT_URL, label="#777000", wait_ms=3000)

        if attempt >= 2:
            print("#777000 最新消息暂未出现可用验证码，继续等待。")
        page.wait_for_timeout(2500)
        attempt += 1

    raise TimeoutError(f"等待 #777000 新验证码超时，最后看到：{format_777000_snapshot(latest_seen)}")

def get_mytelegram_too_many_tries_message(my_page) -> str:
    try:
        body_text = my_page.locator("body").inner_text(timeout=2000)
    except Exception:
        return ""
    normalized = re.sub(r"\s+", " ", body_text or "").strip()
    if not normalized:
        return ""
    if re.search(r"(too\s*many\s*tries|try\s*again\s*later|尝试次数过多|请稍后再试)", normalized, re.IGNORECASE):
        match = re.search(r"Sorry,\s*too\s*many\s*tries\.\s*Please\s*try\s*again\s*later\.?", normalized, re.IGNORECASE)
        return match.group(0) if match else normalized[:500]
    return ""


def assert_mytelegram_not_too_many_tries(my_page, stage: str = ""):
    message = get_mytelegram_too_many_tries_message(my_page)
    if message:
        reason = f"{stage}：{message}" if stage else message
        set_last_automation_result("mytelegram_too_many_tries", reason)
        raise MyTelegramTooManyTriesError(reason)


