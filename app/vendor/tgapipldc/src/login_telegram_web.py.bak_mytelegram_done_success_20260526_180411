def navigate_with_commit(page, url: str, label: str, timeout: int = 8000) -> bool:
    """
    Telegram Web 首屏在高延迟代理下经常超过 domcontentloaded。
    这里按 Playwright 支持的 commit 阶段打开：只要求导航开始并提交，后续交给守护循环等待真实 DOM。
    """
    try:
        url = normalize_telegram_navigation_url(url)
        page.goto(url, wait_until="commit", timeout=timeout)
        return True
    except Exception as e:
        print(f"{label} commit 导航未确认，页面可能仍在后台加载：{e}")
        return False


def normalize_telegram_navigation_url(url: str) -> str:
    """
    Telegram Web 导航必须使用官方原始地址，不拼接任何自定义查询参数。
    如果旧版本留下了非官方查询参数，这里强制回到官方原始地址。
    """
    url = url or TELEGRAM_WEB_URL

    if "web.telegram.org" not in url:
        return url

    if "#777000" in url:
        return TELEGRAM_SERVICE_CHAT_URL

    return TELEGRAM_WEB_URL



def log_current_telegram_page_state(page, label: str = "页面刷新后") -> str:
    """统一打印 Telegram 当前页面状态，便于每次刷新/跳转后判断分支。"""
    try:
        state = get_telegram_page_state(page)
    except Exception as e:
        state = f"state_error: {e}"

    try:
        current_url = page.url or ""
    except Exception:
        current_url = ""

    print(f"{label} 当前页面识别结果：{state}，当前地址：{current_url}")
    return state

def hard_refresh_telegram_page(page, url: str, label: str = "Telegram Web", wait_ms: int = 5000) -> bool:
    """
    硬刷新：Ctrl+F5 / reload 之后，再用 Telegram 官方原始地址重新打开目标页面。
    不能拼接任何自定义查询参数，避免首屏 URL 变形。
    """
    target_url = normalize_telegram_navigation_url(url or page.url or TELEGRAM_WEB_URL)
    print(f"{label} 执行硬刷新：Ctrl+F5 -> reload(commit) -> 原始地址 goto。")
    ok = False

    try:
        page.bring_to_front()
    except Exception:
        pass

    try:
        page.keyboard.press("Control+F5")
        page.wait_for_timeout(800)
        ok = True
    except Exception as e:
        print(f"{label} Ctrl+F5 失败，继续 reload/goto：{e}")

    try:
        page.reload(wait_until="commit", timeout=6000)
        ok = True
    except Exception as e:
        print(f"{label} reload commit 未确认，继续原始地址 goto：{e}")

    try:
        page.goto(target_url, wait_until="commit", timeout=8000)
        ok = True
    except Exception as e:
        print(f"{label} 原始地址 goto 未确认，页面可能仍在后台加载：{e}")

    page.wait_for_timeout(wait_ms)
    log_current_telegram_page_state(page, f"{label} 刷新完成后")
    return ok or not is_telegram_blank_or_error_page(page)

def safe_reload_or_goto(page, url: str, label: str = "页面", wait_ms: int = 3000) -> bool:
    return hard_refresh_telegram_page(page, url or page.url or TELEGRAM_WEB_URL, label=label, wait_ms=wait_ms)


