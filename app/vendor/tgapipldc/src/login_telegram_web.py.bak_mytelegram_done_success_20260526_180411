def wait_after_code_submit_transition(
    page,
    checks_per_round: int = 5,
    max_refresh_rounds: int = 3,
    interval_ms: int = 3000,
) -> str:
    """
    Telegram 登录验证码提交后统一 3x5 守护。
    先等 password/logged_in/phone 等真实状态；3 轮仍 unknown/disabled/code 卡住，就返回 restart。
    """
    print(
        f"Telegram 登录验证码已提交，开始等待页面跳转；每轮检查 {checks_per_round} 次，"
        f"最多 {max_refresh_rounds} 轮；仍不正确就重新打开 Telegram Web。"
    )
    last_state = "unknown"

    for refresh_round in range(1, max_refresh_rounds + 1):
        for check_index in range(1, checks_per_round + 1):
            state = get_telegram_page_state(page)
            last_state = state
            code_ready = locate_code_field(page, timeout=500) is not None if state == "code" else False
            print(
                f"验证码提交后状态检查：轮次 {refresh_round}/{max_refresh_rounds}，"
                f"检查 {check_index}/{checks_per_round}，当前状态：{state}"
                + ("，验证码框可编辑" if code_ready else "")
            )

            if state in {"password", "logged_in", "phone", "phone_entry"}:
                print(f"验证码提交后页面已切换为：{state}")
                return state

            if state == "code" and code_ready and refresh_round > 1:
                print("刷新后仍停在可编辑验证码页，交回主状态机决定是否重试。")
                return "code"

            page.wait_for_timeout(interval_ms)

        if refresh_round < max_refresh_rounds:
            print("本轮 5 次仍未进入 2FA/已登录，执行 Telegram Web 硬刷新。")
            hard_refresh_telegram_page(page, TELEGRAM_WEB_URL, label="Telegram Web 验证码提交后", wait_ms=7000)

    print(f"3x5 后仍未确认验证码提交结果，需要重新打开 Telegram Web。最后状态：{last_state}")
    return "restart"

def wait_after_password_submit_transition(
    page,
    checks_per_round: int = 5,
    max_refresh_rounds: int = 3,
    interval_ms: int = 6000,
) -> str:
    """
    Telegram 2FA 提交后统一 3x5 守护。
    只有确认 logged_in 后才继续 #777000；3 轮仍不正确，返回 restart 重新打开 Telegram Web。
    """
    print(
        f"Telegram 2FA 已提交，开始等待登录完成；每轮检查 {checks_per_round} 次，"
        f"最多 {max_refresh_rounds} 轮；仍不正确就重新打开 Telegram Web。"
    )
    last_state = "unknown"

    for refresh_round in range(1, max_refresh_rounds + 1):
        for check_index in range(1, checks_per_round + 1):
            state = get_telegram_page_state(page)
            last_state = state
            print(
                f"2FA 提交后状态检查：轮次 {refresh_round}/{max_refresh_rounds}，"
                f"检查 {check_index}/{checks_per_round}，当前状态：{state}"
            )

            if state == "logged_in":
                print("2FA 提交后已确认进入 Telegram 已登录状态。")
                return "logged_in"

            if state in {"phone", "phone_entry", "code"}:
                print(f"2FA 提交后页面切换为异常/回退状态：{state}，交回主状态机处理。")
                return state

            page.wait_for_timeout(interval_ms)

        if refresh_round < max_refresh_rounds:
            print("本轮 5 次仍未确认已登录，执行 Telegram Web 硬刷新。")
            hard_refresh_telegram_page(page, TELEGRAM_WEB_URL, label="Telegram Web 2FA 提交后", wait_ms=7000)

    print(f"3x5 后仍未确认 2FA 登录完成，需要重新打开 Telegram Web。最后状态：{last_state}")
    return "restart"

def fill_current_code_page(page, yanzheng_url: str) -> str:
    state = get_telegram_page_state(page)
    if state == "logged_in":
        print("当前已进入 Telegram，不再读取 Telegram 登录验证码。")
        return "logged_in"
    if state == "password":
        print("当前已经进入 Telegram 2FA 页面，不再读取 Telegram 登录验证码。")
        return "password"

    code_field = locate_code_field(page, timeout=120000)
    if code_field is None:
        current_state = get_telegram_page_state(page)
        if current_state in {"password", "logged_in", "phone"}:
            print(f"等待验证码输入框期间页面已切换为：{current_state}")
            return current_state
        raise RuntimeError("当前没有真正可编辑的 Telegram 登录验证码输入框，禁止从 yanzheng 网页读取验证码。")

    code = wait_for_yanzheng_value(yanzheng_url, "code", "Telegram 登录验证码", timeout_seconds=120)
    fill_telegram_text_field(page, code_field, code, "登录验证码")
    maybe_click_next_after_code_or_password(page)
    return wait_after_code_submit_transition(
        page,
        checks_per_round=5,
        max_refresh_rounds=3,
        interval_ms=3000,
    )


def fill_current_password_page(page, yanzheng_url: str) -> str:
    state = get_telegram_page_state(page)
    if state == "logged_in":
        print("当前已进入 Telegram，不再读取 Telegram 2FA。")
        return "logged_in"
    if state != "password":
        print(f"当前不是 2FA 页面，实际状态：{state}，交回主状态机处理。")
        return state

    password_field = locate_password_field(page, timeout=30000)
    if password_field is None:
        current_state = get_telegram_page_state(page)
        print(f"未找到 2FA 输入框，当前状态：{current_state}。")
        return current_state

    pass2fa = wait_for_yanzheng_value(yanzheng_url, "pass2fa", "Telegram 2FA 二步密码", timeout_seconds=120)
    fill_telegram_text_field(page, password_field, pass2fa, "2FA 二步密码")
    maybe_click_next_after_code_or_password(page)
    return wait_after_password_submit_transition(
        page,
        checks_per_round=5,
        max_refresh_rounds=3,
        interval_ms=6000,
    )


def scroll_777000_to_bottom(page):
    try:
        page.evaluate(
            """
            () => {
                const candidates = [
                    document.querySelector('.chat[data-type="chat"] .bubbles .scrollable.scrollable-y'),
                    document.querySelector('#column-center .bubbles .scrollable.scrollable-y'),
                    document.querySelector('.bubbles .scrollable.scrollable-y'),
                    document.querySelector('.bubbles-inner')?.parentElement,
                    document.scrollingElement,
                    document.documentElement,
                    document.body,
                ].filter(Boolean);
                for (const el of candidates) {
                    try {
                        el.scrollTop = el.scrollHeight;
                        el.dispatchEvent(new Event('scroll', { bubbles: true }));
                    } catch (e) {}
                }
                window.scrollTo(0, document.body.scrollHeight || document.documentElement.scrollHeight || 0);
            }
            """,
        )
    except Exception:
        pass




def click_777000_chatlist_row(page, timeout: int = 12000) -> bool:
    """
    从 Telegram Web 左侧聊天列表点击 Telegram 官方服务号 #777000。

    关键原则：
    - 优先点击左侧已经存在的 chatlist 行：a.chatlist-chat[data-peer-id='777000']。
    - 不把 https://web.telegram.org/k/#777000 作为首选打开方式。
    - 点击行后再读取当前中间聊天窗口 DOM，避免 hash 地址打开后 DOM 没稳定导致误判。
    """
    print("正在从左侧聊天列表查找并点击 Telegram 官方服务号 #777000...")

    chat_row_selectors = [
        "a.chatlist-chat[data-peer-id='777000']",
        "a.row.chatlist-chat[data-peer-id='777000']",
        "a[href='#777000'][data-peer-id='777000']",
        "a[href='#777000'].chatlist-chat",
        "#column-left a.chatlist-chat[data-peer-id='777000']",
        "#column-left a[href='#777000']",
        ".chatlist a.chatlist-chat[data-peer-id='777000']",
        ".chatlist a[href='#777000']",
    ]

    deadline = time.time() + timeout / 1000
    attempt = 1
    last_count_info = ""

    while time.time() < deadline:
        try:
            page.bring_to_front()
        except Exception:
            pass

        # 确保当前在 Telegram Web 聊天列表主页面，而不是验证码页 / my.telegram.org / 其它页面。
        if "web.telegram.org" not in (page.url or ""):
            try:
                page.goto(TELEGRAM_WEB_URL, wait_until="commit", timeout=12000)
            except Exception as exc:
                print(f"打开 Telegram Web 主页面失败，继续等待左侧列表：{exc}")
            page.wait_for_timeout(2500)

        for selector in chat_row_selectors:
            locator = page.locator(selector)
            try:
                count = locator.count()
            except Exception:
                count = 0
            if count:
                last_count_info = f"{selector} count={count}"

            for index in range(count):
                item = locator.nth(index)
                try:
                    if not item.is_visible(timeout=800):
                        continue
                    item.scroll_into_view_if_needed(timeout=3000)
                    item.click(timeout=6000)
                    print(f"已点击左侧 #777000 聊天行：selector={selector}, index={index}")
                    page.wait_for_timeout(2500)
                    scroll_777000_to_bottom(page)
                    page.wait_for_timeout(1500)
                    return True
                except Exception as exc:
                    try:
                        item.click(timeout=6000, force=True)
                        print(f"已强制点击左侧 #777000 聊天行：selector={selector}, index={index}")
                        page.wait_for_timeout(2500)
                        scroll_777000_to_bottom(page)
                        page.wait_for_timeout(1500)
                        return True
                    except Exception:
                        print(f"点击 #777000 聊天行失败，继续找下一个候选：{exc}")
                        continue

        # DOM 兜底：不要求可见选择器完全匹配，直接从页面里找 peer-id=777000 的 chatlist 行。
        try:
            clicked_by_dom = page.evaluate(
                """
                () => {
                    function visible(el) {
                        if (!el) return false;
                        const rect = el.getBoundingClientRect();
                        const style = window.getComputedStyle(el);
                        return style
                            && style.display !== 'none'
                            && style.visibility !== 'hidden'
                            && rect.width > 0
                            && rect.height > 0;
                    }
                    const candidates = Array.from(document.querySelectorAll([
                        "a.chatlist-chat[data-peer-id='777000']",
                        "a.row.chatlist-chat[data-peer-id='777000']",
                        "a[href='#777000'][data-peer-id='777000']",
                        "a[href='#777000'].chatlist-chat",
                        "#column-left a[data-peer-id='777000']",
                    ].join(',')));
                    const target = candidates.find(visible) || candidates[0];
                    if (!target) return false;
                    target.scrollIntoView({block: 'center', inline: 'nearest'});
                    target.dispatchEvent(new MouseEvent('mousedown', {bubbles: true, cancelable: true, view: window}));
                    target.dispatchEvent(new MouseEvent('mouseup', {bubbles: true, cancelable: true, view: window}));
                    target.click();
                    return true;
                }
                """
            )
            if clicked_by_dom:
                print("已通过 DOM 方式点击左侧 #777000 聊天行。")
                page.wait_for_timeout(2500)
                scroll_777000_to_bottom(page)
                page.wait_for_timeout(1500)
                return True
        except Exception as exc:
            print(f"DOM 方式点击 #777000 聊天行失败，继续等待：{exc}")

        if attempt % 3 == 0:
            print("暂未找到左侧 #777000 聊天行，回到 Telegram Web 主页面刷新聊天列表。")
            safe_reload_or_goto(page, TELEGRAM_WEB_URL, label="Telegram 聊天列表", wait_ms=4000)
        else:
            print(f"暂未找到左侧 #777000 聊天行，继续等待。最后候选统计：{last_count_info or '无'}")
            page.wait_for_timeout(1200)

        attempt += 1

    print("超过等待时间仍未能从左侧聊天列表点击 #777000。")
    return False


def open_telegram_service_chat(page, timeout: int = 90000) -> bool:
    """
    打开 Telegram 官方服务号 #777000。

    修复点：
    - 不再优先 page.goto(https://web.telegram.org/k/#777000)。
    - 优先在 Telegram Web 左侧聊天列表点击真实会话行：
